{
  "name": "office-power-monitor",
  "version": "1.0.0",
  "description": "Real-time office electricity monitoring system — monorepo root.",
  "private": true,
  "workspaces": [
    "backend",
    "frontend",
    "bot"
  ],
  "scripts": {
    "dev": "concurrently --kill-others-on-fail --names \"backend,frontend\" --prefix-colors \"cyan,magenta\" \"npm run dev -w backend\" \"npm run dev -w frontend\"",
    "dev:backend": "npm run dev -w backend",
    "dev:frontend": "npm run dev -w frontend",
    "dev:bot": "npm run dev -w bot",
    "build": "npm run build -w frontend",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{js,jsx,mjs,cjs,json,md,css,html}\" --ignore-path .prettierignore",
    "format:check": "prettier --check \"**/*.{js,jsx,mjs,cjs,json,md,css,html}\" --ignore-path .prettierignore",
    "install:all": "npm install",
    "clean": "npx rimraf backend/node_modules frontend/node_modules bot/node_modules node_modules"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "concurrently": "^9.0.0",
    "eslint": "^9.28.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "globals": "^16.0.0",
    "prettier": "^3.5.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "author": "Office Power Monitor Team",
  "license": "MIT"
}
