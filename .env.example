# ==========================================
# OFFICE POWER MONITOR - ENVIRONMENT VARIABLES
# ==========================================

# ------------------------------------------
# BACKEND
# ------------------------------------------
# Port the backend server listens on inside the container
PORT=4000
# Optional: Interval in milliseconds for the physics engine simulator
SIMULATOR_TICK_MS=5000
# Optional: Office hours definition for the simulator (24h format)
OFFICE_HOUR_START=9
OFFICE_HOUR_END=17

# ------------------------------------------
# FRONTEND
# ------------------------------------------
# The URL where the frontend will attempt to connect to the backend APIs.
# NOTE: Since the frontend runs in the user's browser, this must be accessible
# from the host machine (e.g. http://localhost:4000 or a public IP/domain), 
# NOT the internal docker network name.
VITE_BACKEND_URL=http://localhost:4000
VITE_SOCKET_URL=http://localhost:4000

# ------------------------------------------
# DISCORD BOT
# ------------------------------------------
# The token for your Discord Bot (keep this secret)
DISCORD_TOKEN=your_discord_bot_token_here
# Prefix for commands (e.g. !status)
COMMAND_PREFIX=!
# Comma-separated list of Channel IDs where automatic real-time alerts are posted
ALERT_CHANNEL_IDS=
# The internal Docker network URL to the backend so the bot can fetch telemetry
# (Since the bot runs inside Docker, it can use the internal service name 'backend')
BACKEND_HTTP_URL=http://backend:4000
BACKEND_WS_URL=http://backend:4000

# ------------------------------------------
# OPENAI (Optional for Discord Bot)
# ------------------------------------------
# If provided, the Discord bot will use this key to rewrite raw data into
# friendly human summaries. If blank or invalid, it falls back to rigid templates.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# To use Hugging Face, change this to: https://router.huggingface.co/v1
# To use Ollama/LocalAI, change this to: http://localhost:11434/v1
OPENAI_BASE_URL=https://api.openai.com/v1
