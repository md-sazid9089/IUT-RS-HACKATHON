{
  "name": "office-power-monitor-backend",
  "version": "1.0.0",
  "description": "Backend service for the Office Power Monitor: simulator, REST API, Socket.IO and Discord integration.",
  "main": "src/server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "lint": "eslint src --max-warnings=0",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.{js,json}\"",
    "format:check": "prettier --check \"src/**/*.{js,json}\""
  },
  "keywords": [
    "iot",
    "power-monitor",
    "socket.io",
    "express",
    "simulator"
  ],
  "author": "Office Power Monitor Team",
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "socket.io": "^4.7.5"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  }
}
